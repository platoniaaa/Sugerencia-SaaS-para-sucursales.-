# ============================================================
#  Plataforma "Sugerido de Compras" - variables de entorno
#  Copia este archivo a .env y ajusta lo que necesites.
# ============================================================

# ---------- Backend (apps/api) ----------

# Base de datos.
# Fase 0 (por defecto): SQLite local, no requiere instalar nada.
DATABASE_URL=sqlite:///./data/sugerido.db
#
# Para migrar a PostgreSQL en el futuro (Fase 2 / produccion), usar algo como:
# DATABASE_URL=postgresql+psycopg://sugerido:sugerido@localhost:5432/sugerido

# Tenant por defecto (multi-tenant llega en Fase 2; por ahora todo es "curifor")
DEFAULT_TENANT_ID=curifor

# Usuario admin placeholder (auth real llega despues)
ADMIN_EMAIL=francisco@curifor.cl

# CORS: origenes permitidos para el frontend
CORS_ORIGINS=http://localhost:3000

# ---------- Ingesta automatica desde Power BI (opcional) ----------
# Si se completan, se habilita la sincronizacion directa desde Power BI Service
# (boton "Sincronizar con Power BI" y el job programado src.jobs.sync_powerbi).
# Si quedan vacias, la app funciona igual cargando por Excel/CSV.
#
# Estos valores los entrega un admin de Microsoft 365 al registrar la app en Entra ID
# (ver docs/powerbi-sync.md):
POWERBI_TENANT_ID=
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=
POWERBI_GROUP_ID=
POWERBI_DATASET_ID=
# Consulta DAX para extraer la tabla (ajusta el nombre si tu tabla se llama distinto):
POWERBI_DAX_QUERY=EVALUATE FILTER('Sugerido por Sucursal', 'Sugerido por Sucursal'[pedir] = "Si")

# ---------- Frontend (apps/web) ----------

# URL del backend que usa el frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
